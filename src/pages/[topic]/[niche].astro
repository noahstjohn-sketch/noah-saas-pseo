---
// src/pages/[topic]/[niche].astro
// SSR mode. Only renders when topic.kind === 'atomic'.
// Longtail topics (including vs comparisons): cross pages return 404.
import Base from '../../layouts/Base.astro';
import PageTemplate from '../../components/PageTemplate.astro';
import { topics } from '../../data/topics.js';
import { niches } from '../../data/niches.js';
import { buildPageData } from '../../lib/page-data.js';

const BUYER_SINGULAR = 'SaaS founder';

const { topic: topicSlug, niche: nicheSlug } = Astro.params;
const topic = topics.find(t => t.slug === topicSlug);
const niche = niches.find(n => n.slug === nicheSlug);

if (!topic || !niche) return Astro.redirect('/404');
if (topic.kind !== 'atomic') return Astro.redirect('/404');

const { faq, faqSchema, aboutText } = buildPageData(topic, niche, { buyerSingular: BUYER_SINGULAR });

const title = `${topic.label} for ${niche.label} | Dr. Noah St. John | Neural Performance Architect`;
const description = `${topic.label} for ${niche.label}: Release the Invisible Brake capping SaaS founders. Dr. Noah St. John. 28 years. $3 billion in client results.`;
const canonical = `https://saas.noahstjohn.com/${topic.slug}/${niche.slug}`;
---
<Base title={title} description={description} canonical={canonical} faqSchema={faqSchema}>
  <PageTemplate topic={topic} niche={niche} faq={faq} aboutText={aboutText} />
</Base>
